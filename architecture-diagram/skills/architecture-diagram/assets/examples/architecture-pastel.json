        { "id": "api-gateway", "label": "API Gateway", "type": "module" }
      ]
    },
    {
      "id": "services-layer",
      "label": "Microservices",
      "type": "process",
      "children": [
        { "id": "user-svc", "label": "User Service", "type": "module" },
        { "id": "order-svc", "label": "Order Service", "type": "module" },
        { "id": "payment-svc", "label": "Payment Service", "type": "module" },
        { "id": "notification-svc", "label": "Notification Service", "type": "module" }
      ]
    },
    {
      "id": "platform-layer",
      "label": "Platform Services",
      "type": "infra",
      "children": [
        { "id": "service-mesh", "label": "Service Mesh", "type": "module", "tech": ["Istio"] },
        { "id": "config-center", "label": "Config Center", "type": "module" },
        { "id": "service-discovery", "label": "Service Discovery", "type": "module" }
      ]
    },
    {
      "id": "data-layer",
      "label": "Data & Storage",
      "type": "data",
      "children": [
        { "id": "primary-db", "label": "PostgreSQL", "type": "data" },
        { "id": "cache", "label": "Redis Cache", "type": "data" },
        { "id": "message-broker", "label": "Message Broker", "type": "channel", "tech": ["Kafka"] }
      ]
    },
    {
      "id": "observability-layer",
      "label": "Observability",
      "type": "external",
      "children": [
        { "id": "metrics", "label": "Metrics", "type": "module", "tech": ["Prometheus"] },
        { "id": "logging", "label": "Logging", "type": "module" },
        { "id": "tracing", "label": "Tracing", "type": "module" }
      ]
    }
  ],
  "connections": [
